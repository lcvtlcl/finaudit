# Скопируй в .env и заполни. .env в git НЕ коммитится.

# HTTP
HTTP_ADDR=:8080

# Postgres (пароль один и тот же в POSTGRES_PASSWORD и внутри POSTGRES_DSN)
POSTGRES_PASSWORD=changeme
POSTGRES_DSN=postgres://finaudit:changeme@postgres:5432/finaudit?sslmode=disable

# ClickHouse
CLICKHOUSE_ADDR=localhost:9000
CLICKHOUSE_DB=finaudit

# DeepSeek (модель указываем v4-flash напрямую: алиас deepseek-chat отключают 24.07.2026)
DEEPSEEK_API_KEY=sk-xxxxx
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Шифрование персональных ключей ИИ (AES-256-GCM). Сгенерировать: openssl rand -base64 32
# Пусто -> персональные ключи выключены, работает глобальный DeepSeek-ключ (демо).
APP_ENC_KEY=

# Проверка контрагентов по ИНН (ЕГРЮЛ/ЕГРИП через DaData). Пусто -> блок отключён.
DADATA_API_KEY=

# Приём оплаты подписки (ЮKassa). Пусто -> онлайн-оплата отключена,
# остальной сервис (аудит, прогноз, риски) работает без изменений.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Публичный адрес сервиса: используется как return_url после оплаты
# и как адрес для вебхука ЮKassa (POST {PUBLIC_BASE_URL}/api/billing/webhook).
PUBLIC_BASE_URL=https://finaudit.site

# Оповещения команды в Telegram: заявки с сайта и успешные оплаты.
# Токен — у @BotFather. CHAT_ID — id чата/канала, куда бот шлёт алерты:
#   1) напишите боту любое сообщение (или добавьте его в группу);
#   2) откройте https://api.telegram.org/bot<ТОКЕН>/getUpdates и возьмите оттуда chat.id.
# Пусто -> оповещения выключены, остальной сервис работает без изменений.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Если api.telegram.org с сервера недоступен ("context deadline exceeded") —
# два способа обойти, любой на выбор.
#
# 1) Прокси до Telegram API. Схемы: http://, https://, socks5://
#    (можно с авторизацией: socks5://user:pass@host:1080)
TELEGRAM_PROXY_URL=
#
# 2) Свой релей Bot API — например, Cloudflare Worker, который перенаправляет
#    запросы на api.telegram.org. На сервер ставить ничего не нужно.
#    Пример: https://tg-relay.ваш-аккаунт.workers.dev
TELEGRAM_API_BASE_URL=
