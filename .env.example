# Скопируй в .env и заполни. .env в git НЕ коммитится.

# HTTP
HTTP_ADDR=:8080

# Postgres (пароль один и тот же в POSTGRES_PASSWORD и внутри POSTGRES_DSN)
POSTGRES_PASSWORD=changeme
POSTGRES_DSN=postgres://finaudit:changeme@postgres:5432/finaudit?sslmode=disable

# ClickHouse
CLICKHOUSE_ADDR=localhost:9000
CLICKHOUSE_DB=finaudit

# DeepSeek (модель указываем v4-flash напрямую: алиас deepseek-chat отключают 24.07.2026)
DEEPSEEK_API_KEY=sk-xxxxx
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Шифрование персональных ключей ИИ (AES-256-GCM). Сгенерировать: openssl rand -base64 32
# Пусто -> персональные ключи выключены, работает глобальный DeepSeek-ключ (демо).
APP_ENC_KEY=
