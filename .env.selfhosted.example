# Self-hosted: скопируй в .env.selfhosted и заполни своими значениями.
# Этот файл — только шаблон, реальные секреты в git НЕ коммитятся.

# Пароль Postgres (должен совпадать с паролем внутри POSTGRES_DSN)
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DSN=postgres://finaudit:replace_with_strong_password@postgres:5432/finaudit?sslmode=disable

# Шифрование персональных ключей ИИ (AES-256-GCM). Сгенерировать: openssl rand -base64 32
APP_ENC_KEY=replace_with_your_32_byte_key

# Ключ DeepSeek для слоя объяснений
DEEPSEEK_API_KEY=sk-xxxxx
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Проверка контрагентов по ЕГРЮЛ/ЕГРИП (опционально)
DADATA_API_KEY=
